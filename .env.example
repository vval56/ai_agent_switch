# NVIDIA API — Llama 3.3 70B (поддерживает tool calling, бесплатный API)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_NAME=meta/llama-3.3-70b-instruct

# Уведомления в Telegram (ошибки диагностики коммутаторов)
# TELEGRAM_CHAT_ID должен быть ЧИСЛОВЫМ id чата, а НЕ @username бота!
# Узнать: отправь боту сообщение, затем открой https://api.telegram.org/bot<TOKEN>/getUpdates
# и возьми "chat":{"id": <ЧИСЛО>}
TELEGRAM_BOT_TOKEN=8950039330:AAFrPOFo06YX55oP07wj8BPmFpPYDtGsZZU
TELEGRAM_CHAT_ID=1456176013

# Настройки окружения
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

# Monitor service
SYSLOG_ENABLED=true
SYSLOG_PORT=1514
SSH_POLL_ENABLED=true
MONITOR_POLL_INTERVAL=60